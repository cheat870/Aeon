# Flask
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# ABA / KHQR
# Paste your ABA merchant KHQR payload string here (it usually starts with 000201...)
# Example:
# ABA_KHQR_BASE=000201010211....6304ABCD
ABA_KHQR_BASE=

# Admin payment confirmation
# Used to confirm orders as paid after money is received in ABA.
# Call POST /api/payments/admin/confirm with header X-Admin-Secret.
PAYMENT_CONFIRM_SECRET=change-me

# JWT
# Increase/decrease login duration (days)
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# Telegram bot (admin)
# Put your bot token here (keep it secret, do not commit .env)
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use admin commands (get yours with /myid)
TELEGRAM_ADMIN_IDS=
