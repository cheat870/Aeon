# Flask
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Bakong / KHQR
# Paste your Bakong merchant KHQR payload string here (it usually starts with 000201...)
# Example:
# BAKONG_KHQR_BASE=000201010211....6304ABCD
BAKONG_KHQR_BASE=

# Optional: enable automatic payment confirmation by checking Bakong's
# "check_transaction_by_md5" API with a Bearer token.
# Without this token, payment stays manual (/confirm or admin API).
BAKONG_API_TOKEN=

# Optional: enable ABA PayWay webhook auto-confirm.
# Put a random secret here, then give ABA/PayWay this full webhook URL:
# https://your-domain/api/payments/aba/webhook/<ABA_WEBHOOK_TOKEN>
ABA_WEBHOOK_TOKEN=

# Admin payment confirmation
# Used to confirm orders as paid after money is received in Bakong.
# Call POST /api/payments/admin/confirm with header X-Admin-Secret.
PAYMENT_CONFIRM_SECRET=change-me

# JWT
# Increase/decrease login duration (days)
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# Telegram polling inside the web app process
# Set to 1 on Render if you want the admin bot to run in the same service as Flask.
RUN_TELEGRAM_BOT_IN_WEB=0

# Telegram bot (admin + auth notifications)
# Put your bot token here (keep it secret, do not commit .env)
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use admin commands and receive auth event logs (get yours with /myid)
TELEGRAM_ADMIN_IDS=
